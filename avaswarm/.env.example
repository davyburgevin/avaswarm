# ==============================================
#  project-swarm  —  environment configuration
# ==============================================

# ---- Active LLM provider ----
# Choices: openai | anthropic | openrouter | github_copilot | vllm
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o

# ---- OpenAI ----
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# ---- Anthropic ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- OpenRouter ----
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---- GitHub Copilot (OAuth token) ----
GITHUB_COPILOT_TOKEN=ghu_...

# ---- vLLM / local model ----
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=mistral-7b

# ---- Web gateway ----
WEB_HOST=0.0.0.0
WEB_PORT=8080
WEB_SECRET_KEY=change-me-in-production

# ---- Email gateway ----
EMAIL_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_ADDRESS=your@email.com
EMAIL_PASSWORD=your-app-password
EMAIL_CHECK_INTERVAL=60   # seconds

# ---- Memory ----
MEMORY_DIR=memory
LONG_TERM_FILE=MEMORY.md

# ---- Web search (Brave) ----
BRAVE_SEARCH_API_KEY=BSA...

# ---- Scheduler timezone ----
SCHEDULER_TIMEZONE=Europe/Paris

# ---- Skills / ClawHub ----
CLAWHUB_BASE_URL=https://clawhub.io/api/v1
CLAWHUB_API_KEY=
